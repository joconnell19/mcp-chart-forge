{
  "name": "mcp-chart-forge",
  "version": "1.0.0",
  "description": "MCP server for generating beautiful, on-brand charts as PNG and SVG — fully local, no API keys required",
  "main": "dist/index.js",
  "bin": {
    "mcp-chart-forge": "dist/index.js",
    "chart-forge": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev:mcp": "ts-node src/index.ts",
    "dev:cli": "ts-node src/cli.ts",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "start:cli": "node dist/cli.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "charts",
    "vega",
    "visualization",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^14.0.3",
    "sharp": "^0.33.5",
    "vega": "^5.30.0",
    "vega-lite": "^5.21.0",
    "zod": "^3.22.0"
  },
  "optionalDependencies": {
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "playwright": "^1.58.2",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
